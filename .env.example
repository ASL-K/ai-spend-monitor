# ai-spend-monitor 环境变量示例
#
# 复制这个文件为 .env, 然后填入真 key:
#   cp .env.example .env
#   nano .env   # 或用记事本/VSCode
#
# ⚠️ .env 已在 .gitignore 里, 不会进 git 历史
# ⚠️ 但 B 项目本身**不读 .env**! 这是**给 client 代码用的**参考
#
# 真实用法是把这些 key 设到 PowerShell 环境变量:
#   [Environment]::SetEnvironmentVariable("DEEPSEEK_API_KEY", "sk-你的真key", "User")

# ===== DeepSeek =====
# 申请地址: https://platform.deepseek.com/
# 价格:     ¥1/M input, ¥2/M output (cache 命中 ¥0.1/M)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ===== MiniMax =====
# 申请地址: https://api.minimaxi.com/
# 价格:     按 token 计费, 49 元套餐 2 亿 token/月
MINIMAX_API_KEY=eyJ-your-minimax-key-here

# ===== B 项目本身的环境变量（可选, 都有默认值）=====

# HTTP 端口 (默认 8123)
# AISM_PORT=8123

# 绑定 host (默认 127.0.0.1, 不要改成 0.0.0.0 否则局域网能访问你的仪表盘)
# AISM_HOST=127.0.0.1

# SQLite 路径 (默认 ./data/ai-spend.db)
# AISM_DB_PATH=./data/ai-spend.db

# 月度预算 CNY (默认 49, 你的 MiniMax 套餐价格)
# AISM_BUDGET_CNY=49

# 日志级别: debug / info / warn / error / silent (默认 info)
# AISM_LOG_LEVEL=info
